# ============================================
# pushIT Configuration
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://push.example.com

# Database
DB_PATH=./data/pushit.db

# Microsoft Entra ID (Azure AD)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret-here

# VAPID Keys for Web Push (generate with: npm run vapid:generate)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# n8n Integration (optional)
N8N_BASE_URL=https://n8n.example.com
N8N_WEBHOOK_SECRET=generate-a-strong-secret-here

# Application Proxy Header-based SSO (optional)
# These must match the claim-to-header mappings configured in Azure Portal.
# Default values work if you follow the setup guide (SETUP-SSO.md).
# PROXY_HEADER_EMAIL=x-user-email
# PROXY_HEADER_DISPLAYNAME=x-user-displayname
# PROXY_HEADER_OBJECTID=x-user-objectid
# PROXY_HEADER_UPN=x-user-upn

# Session Secret
SESSION_SECRET=generate-a-strong-random-string-here

# Emergency notification retry defaults
EMERGENCY_RETRY_INTERVAL=60
EMERGENCY_MAX_DURATION=10800
